{
  "compilerOptions": {
    "module": "commonjs",
    "target": "esnext",
    "types": ["node"],

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["src", "drizzle.config.ts"],
  "exclude": ["node_modules", "dist", "drizzle"]
}
